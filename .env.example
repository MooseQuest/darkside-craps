# =============================================================================
# Local development (no vault)
# =============================================================================
# When INFISICAL_CLIENT_ID is unset, secrets_loader.load() falls back to
# reading these directly from the environment. Use this for local Mongo:
#
# MONGO_URI=mongodb://localhost:27017/
# SESSION_MONGO_URI=mongodb://localhost:27017/
# SECRET_KEY=dev-only-not-secret
# FLASK_ENV=development
# PORT=5001

# =============================================================================
# Production / staging (Infisical at vault.raxx.app)
# =============================================================================
# When all four INFISICAL_* vars below are set, secrets_loader fetches
# MONGO_URI, SESSION_MONGO_URI and SECRET_KEY from the root path (/) of the
# mqcraps project in Infisical instead of reading them from the env. Plain
# MONGO_URI in env is ignored in that case.

# INFISICAL_HOST=https://vault.raxx.app
# INFISICAL_PROJECT_ID=<workspace-uuid>
# INFISICAL_ENV=prod

# Auth — provide ONE of:
#   (a) Service token (st.xxx.yyy.zzz format, used directly as bearer)
# INFISICAL_SERVICE_TOKEN=<st.xxx.yyy.zzz>
#   (b) Universal Auth machine identity (clientId + clientSecret → access token)
# INFISICAL_CLIENT_ID=<machine-identity-client-id>
# INFISICAL_CLIENT_SECRET=<machine-identity-client-secret>

# CF Access service token (only if vault.raxx.app is gated by Cloudflare Access)
# CF_ACCESS_CLIENT_ID=<service-token-id>
# CF_ACCESS_CLIENT_SECRET=<service-token-secret>
